# LYRA — конфигурация окружения. Скопируйте в .env и заполните значения.
# Секреты в репозиторий не попадают: .env в .gitignore (docs/security-and-access.md §5).

# --- Приложение ---
LYRA_ENV=dev
# Сгенерируйте: openssl rand -hex 32
LYRA_JWT_SECRET=<random-64-hex>
LYRA_ADMIN_EMAIL=admin@lyra.local
LYRA_ADMIN_PASSWORD=<strong-password>

# --- PostgreSQL ---
LYRA_DB_HOST=postgres
LYRA_DB_PORT=5432
LYRA_DB_USER=lyra
LYRA_DB_PASSWORD=<db-password>
LYRA_DB_NAME=lyra

# --- Инфраструктурные сервисы (дефолты = docker-compose; менять не нужно) ---
LYRA_REDIS_URL=redis://redis:6379/0
LYRA_OLLAMA_URL=http://ollama:11434
LYRA_EMBEDDINGS_URL=http://embeddings:80
LYRA_RERANKER_URL=http://reranker:80

# --- Chat API (фаза 5; дефолты рабочие, менять по необходимости) ---
# Origin фронтенда для CORS (через запятую, если несколько)
# LYRA_CORS_ORIGINS=http://localhost:5173
# Лимиты: чат per-user и логин per-IP (запросов в минуту), одновременные генерации LLM
# LYRA_RATE_LIMIT_CHAT_PER_MINUTE=10
# LYRA_RATE_LIMIT_LOGIN_PER_MINUTE=5
# LYRA_LLM_MAX_CONCURRENCY=2

# --- Коннекторы (фаза 2) ---
# API-токен Confluence Cloud: https://id.atlassian.com/manage-profile/security/api-tokens
# В БД хранится только имя этой переменной (token_secret_ref), не значение.
CONFLUENCE_TOKEN=<atlassian-api-token>
